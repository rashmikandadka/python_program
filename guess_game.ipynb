   "source": [
    "import random\n",
    "\n",
    "number = random.randint(1, 10)\n",
    "\n",
    "guess = int(input(\"Guess a number between 1 and 10: \"))\n",
    "\n",
    "if guess == number:\n",
    "    print(\"Correct! You guessed the number.\")\n",
    "else:\n",
    "    print(\"Wrong! The number was\", number)"
   ]
