    "# Palindrome Check\n",
    "\n",
    "text = input(\"Enter a word: \")\n",
    "\n",
    "if text == text[::-1]:\n",
    "    print(\"It is a Palindrome\")\n",
    "else:\n",
    "    print(\"Not a Palindrome\")"
